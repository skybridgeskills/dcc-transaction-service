DEFAULT_EXCHANGE_HOST=http://localhost:4004
REDIS_URI=redis://127.0.0.1:6379
KEYV_WRITE_DELAY=50
STATUS_SERVICE="http://localhost:4006" # default, remove to disable

# Tenant auth (server + CLI) - set TENANT_TOKEN_DEFAULT to enable server auth
TENANT_TOKEN_DEFAULT=example-tenant-token
TENANT_TOKEN_OTHERTENANT=example-other-tenant-token

# Optional: multiple issuer instances per tenant (signing-service tenant + DID + cryptosuite).
# TENANT_ISSUER_1_ID_EDDSATEST=did:web:example.com
# TENANT_ISSUER_1_CRYPTOSUITE_EDDSATEST=eddsa-rdfc-2022
# TENANT_ISSUER_1_SIGNING_TENANT_EDDSATEST=eddsatest

# OAuth2 client_credentials access JWT (HS256). Required to issue tokens at POST /oauth/token.
# client_id in token requests must match tenant name (same key as TENANT_TOKEN_<name>, lowercased).
ACCESS_JWT_SECRET=generate-a-long-random-secret-for-production

# Optional VC Recognition issuer registries (repeat per slug).
# Registry name for trustedRegistries / DEFAULT_TRUSTED_REGISTRIES is VC_RECOGNITION_<SLUG>.
# REGISTRY_VC_RECOGNITION_SKY_URL=https://issuer.example/recognition-vc.json
# REGISTRY_VC_RECOGNITION_SKY_ACCEPTED_ISSUERS=did:web:trusted-issuer.example

# CLI configuration
CLI_TENANT_TOKEN=example-tenant-token
# CLI_EXCHANGE_HOST=https://your-tunnel.ngrok.io  # override public exchange host (defaults to server's DEFAULT_EXCHANGE_HOST)
