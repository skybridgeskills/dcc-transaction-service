{
  "name": "@digitalcredentials/transaction-service",
  "description": "A web app for managing DID Auth and other VC-API exchanges.",
  "version": "0.3.1",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "vite build",
    "build:tsc": "tsc",
    "start": "node -r dotenv/config build/index.js",
    "dev": "vite dev",
    "dev:old": "nodemon -r dotenv/config --exec tsx src/server.ts",
    "dev-noenv": "nodemon --exec tsx src/server.ts",
    "preview": "vite preview",
    "test": "dotenvx run -f src/test-fixtures/.env.testing -- vitest run",
    "coverage": "dotenvx run -f src/test-fixtures/.env.testing -- vitest run --coverage",
    "prepare": "husky",
    "lint": "eslint",
    "lint-fix": "eslint --fix",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "test:storybook": "vite optimize --force && vitest run --reporter=verbose --no-file-parallelism --no-coverage"
  },
  "dependencies": {
    "@digitalbazaar/credentials-context": "^3.2.0",
    "@digitalbazaar/data-integrity": "^2.5.0",
    "@digitalbazaar/did-method-key": "^5.3.0",
    "@digitalbazaar/ecdsa-rdfc-2019-cryptosuite": "^1.2.0",
    "@digitalbazaar/ed25519-multikey": "^1.3.1",
    "@digitalbazaar/ed25519-signature-2020": "^5.4.0",
    "@digitalbazaar/ed25519-verification-key-2020": "^4.1.0",
    "@digitalbazaar/eddsa-rdfc-2022-cryptosuite": "^1.2.0",
    "@digitalbazaar/vc": "^7.0.0",
    "@digitalcredentials/security-document-loader": "^6.0.0",
    "@digitalcredentials/verifier-core": "1.0.0-beta.11",
    "@hono/node-server": "^1.14.4",
    "@keyv/redis": "^4.4.0",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^16.0.3",
    "express": "^5.1.0",
    "handlebars": "^4.7.8",
    "hono": "^4.7.11",
    "keyv": "^5.3.3",
    "keyv-file": "^5.1.2",
    "morgan": "~1.9.1",
    "nodemailer": "^6.9.14",
    "qrcode": "^1.5.4",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.20.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.44.1",
    "@eslint/js": "^9.3.0",
    "@iconify-json/material-symbols-light": "^1.2.53",
    "@iconify-json/mdi-light": "^1.2.2",
    "@iconify/tailwind4": "^1.2.1",
    "@storybook/addon-a11y": "10.0.2",
    "@storybook/addon-docs": "10.0.2",
    "@storybook/addon-svelte-csf": "^5.0.10",
    "@storybook/addon-vitest": "10.0.2",
    "@storybook/sveltekit": "10.0.2",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/chai": "^5.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.15.30",
    "@types/supertest": "^6.0.3",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "bits-ui": "^2.15.4",
    "chai": "^4.3.7",
    "coveralls": "^3.1.1",
    "eslint": "^9.3.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.3.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "nock": "^13.5.4",
    "nodemon": "^2.0.21",
    "playwright": "^1.57.0",
    "prettier": "3.2.5",
    "storybook": "10.0.2",
    "supertest": "^6.3.3",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.8.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.15"
  },
  "keywords": [
    "dcc"
  ],
  "engines": {
    "node": ">=22.0"
  },
  "author": {
    "name": "Digital Credentials Consortium",
    "url": "https://github.com/digitalcredentials/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalcredentials/transaction-manager-service"
  },
  "homepage": "https://github.com/digitalcredentials/transaction-manager-service",
  "bugs": "https://github.com/digitalcredentials/transaction-manager-service/issues",
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.{js,css,md}": "prettier --write"
  }
}
